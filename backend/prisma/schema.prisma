generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// model contoh untuk verifikasi koneksi — diganti di tahap A2 (schema lengkap)
model HealthCheck {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}
